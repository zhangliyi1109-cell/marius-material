# 复制为项目根目录 .env 后填写（应用启动时会自动读取）
PORT=8080

# 登录：MATERIAL_AUTH_PASSWORD 非空即启用
SECRET_KEY=请运行 openssl rand -hex 32 生成
MATERIAL_AUTH_USER=admin
MATERIAL_AUTH_PASSWORD=请设置你的密码

# 视觉打标 API（在 inventory_config.json 的 vision.provider 切换 xiaomi / kimi）
XIAOMI_API_KEY=
KIMI_API_KEY=
# 也可用 MOONSHOT_API_KEY（与 KIMI_API_KEY 二选一）

# 可选：guancli 若用环境变量方式配置 BI
# GUANCLI_BASE_URL=
# GUANCLI_TOKEN=
