[Unit]
Description=MARIUS Material Inventory (button + fabric)
After=network.target

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/root/marius-material
EnvironmentFile=-/root/marius-material/.env
Environment=PATH=/usr/local/bin:/usr/bin:/bin
Environment=HOME=/var/www
ExecStart=/root/marius-material/venv/bin/gunicorn -w 2 -b 127.0.0.1:8080 material_app:app
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
